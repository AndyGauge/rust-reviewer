# Rust build output
/target

# Training data — large, regenerable from reviewer-extract/prepare, not source.
# raw/ = crawled GitHub comments; prepared/ = the SFT JSONL.
/data/

# Model artifacts, checkpoints, adapters, metrics, and run logs (live on the box)
/train/out/
/train/.venv/
*.log
*.checkpoint

# Python caches (Path B training scripts)
__pycache__/
*.pyc

# Local review-harness output
/review.html
*.review.html
# Captured critic findings (runtime record; regenerable, may hold large diffs)
findings.jsonl
*.findings.jsonl

# macOS
.DS_Store

# Path A oracle dumps (regenerable from oracle_dump.py; can be large)
oracle_*.safetensors
*_synth.safetensors

# Tokenizer/config files copied down from the box for offline dev (regenerable)
/.models/
/train/.venv-tok/
new_code_prompts.jsonl
review_curated.jsonl
